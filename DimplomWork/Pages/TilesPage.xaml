<Page x:Class="DimplomWork.Pages.TilesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DimplomWork.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TilesPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <!-- Важно: звездочка для скролла -->
        </Grid.RowDefinitions>

        <ListBox Margin="10,0,10,-3" 
             Background="GhostWhite" 
             SelectionMode="Multiple" 
             Name="TilesLb" 
             Grid.Row="2" 
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
             BorderThickness="0" ItemsSource="{Binding TilesView}">

            <!-- Задача 1: Три позиции в ряду через UniformGrid -->
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3" 
                            Rows="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- Добавляем фиксированную ширину для каждой карточки -->
                    <Border BorderBrush="LightGray" 
                        BorderThickness="1" 
                        CornerRadius="10" 
                        Margin="5" 
                        Background="White"
                        Padding="5">
                        <Grid Width="150">
                            <!-- Фиксированная ширина -->
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Центрируем изображение -->
                            <Border Grid.Row="0" 
                                HorizontalAlignment="Center" 
                                Margin="-10,5,-10,5">
                                <Image Source="{Binding photo}" 
                                   Height="70" 
                                   Width="90" 
                                   Stretch="Fill"
                                       
                                   />
                            </Border>

                            <StackPanel Grid.Row="1" 
                                    Orientation="Vertical" 
                                    Margin="5,0,0,0">
                                <TextBlock Text="{Binding Name}" 
                                       TextWrapping="Wrap" 
                                       TextAlignment="Center"
                                       FontWeight="Bold"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2" 
                                   Text="{Binding price, StringFormat={}{0} руб.}" 
                                   TextWrapping="Wrap" 
                                   TextAlignment="Center"
                                   Foreground="Green"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,5"/>

                            <Button Grid.Row="3" 
                                Name="OrderBtn"  
                                Content="Подробнее" 
                                Margin="5" 
                                HorizontalAlignment="Center"
                                Width="100"
                                Height="30"
                                Background="#007ACC"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Tag="{Binding}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
