<Page x:Class="DimplomWork.Pages.ProductsDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DimplomWork.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="300" d:DesignWidth="500"
      Title="ProductsDetailsPage">

    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="8" Padding="12" Margin="5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="195"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- Левая часть: картинка + счётчик -->
            <Grid Grid.Column="0" Margin="0,0,15,0" VerticalAlignment="Center" Height="160">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Прямоугольник с изображением -->
                <Border Grid.Row="0" Width="180" Height="120"  
                        Background="#F0F0F0" BorderBrush="#999" 
                        BorderThickness="1" CornerRadius="4" Margin="0,0,0,10">
                    <Image Source="{Binding photo, FallbackValue=default_image.png}" 
                           Stretch="Uniform"  Margin="5"/>
                </Border>

                <!-- Счётчик: -  количество  + -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Orientation="Horizontal">
                    <Button Name="MinusButton" Content="-" Width="30" Height="30" 
                            FontSize="16" FontWeight="Bold"/>

                    <TextBox Name="QuantityTextBox" Text="{Binding stock_quantity, UpdateSourceTrigger=PropertyChanged}" 
                             Width="50" Height="30" TextAlignment="Center" 
                             FontSize="14" Margin="5,0" VerticalContentAlignment="Center"/>

                    <Button Name="PlusButton" Content="+" Width="30" Height="30" 
                            FontSize="16" FontWeight="Bold" />
                </StackPanel>
            </Grid>

            <!-- Правая часть: название, цена, описание, кнопка -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center"   Margin="10,0,10,0" Height="134">


                <!-- Название товара -->
                <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" 
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <!-- Цена -->
                <TextBlock Text="{Binding price, StringFormat=C}" FontSize="16" 
                           Foreground="#E67E22" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <!-- Описание -->
                <TextBlock Text="{Binding description}" FontSize="13" 
                           TextWrapping="Wrap" Foreground="#555" 
                           Margin="0,0,0,15" LineHeight="20"/>
                <!-- Горизонтальный StackPanel для кнопок -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <!-- Кнопка добавить в заказ -->
                    <Button Content="Назад" Width="100" Height="35" Margin="10,0,10,0"
                        Background="Blue" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" 
                        >
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <!-- Кнопка добавить в заказ -->
                    <Button  Content="Добавить в заказ" Width="120" Height="35" 
                        Background="Blue" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" 
                        >
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Page>
