<Page x:Class="DimplomWork.Pages.SupliersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DimplomWork.Pages"
      mc:Ignorable="d" 
     d:DesignHeight="450" d:DesignWidth="800"
      Title="SuppliersPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Строка поиска -->
        <TextBox x:Name="SearchTb" 
                 Grid.Row="0"
                 Margin="10"
                 Padding="10,5"
                 Tag="Поиск по названию, телефону или email"
                 TextChanged="SearchTb_TextChanged"/>

        <!-- ListView с поставщиками -->
        <ListView x:Name="SuppliersLv" 
                  Grid.Row="1"
                  Margin="10"
                  Background="GhostWhite"
                  SelectionMode="Single">

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Название" Width="200" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Телефон" Width="120" DisplayMemberBinding="{Binding Phone}"/>
                    <GridViewColumn Header="Email" Width="180" DisplayMemberBinding="{Binding Email}"/>
                    <GridViewColumn Header="Адрес" Width="200" DisplayMemberBinding="{Binding Address}"/>
                    <GridViewColumn Header="Контактное лицо" Width="150" DisplayMemberBinding="{Binding ContactPerson}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>