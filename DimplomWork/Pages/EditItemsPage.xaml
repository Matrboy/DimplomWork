<Page x:Class="DimplomWork.Pages.EditItemsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DimplomWork.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="600"
       Title="EditItemPage">

    <Grid Background="White">
        <Border Width="420"
                Padding="20"
                CornerRadius="10"
                Background="White"
                BorderBrush="LightGray"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,20,0,0">
            <StackPanel>

                <TextBlock Text="Редактирование товара"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Название" Margin="0,0,0,5"/>
                <TextBox Name="NameTb"
                         Height="30"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Цена" Margin="0,0,0,5"/>
                <TextBox Name="PriceTb"
                         Height="30"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Фото" Margin="0,0,0,5"/>
                <TextBox Name="PhotoTb"
                         Height="30"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Тип камня" Margin="0,0,0,5"/>
                <ComboBox Name="StoneTypeCmb"
                          Height="30"
                          Margin="0,0,0,10"/>

                <TextBlock Text="Тон" Margin="0,0,0,5"/>
                <ComboBox Name="ToneCmb"
                          Height="30"
                          Margin="0,0,0,20"/>

                <Button Content="Сохранить изменения"
                        Height="35"
                        Background="RoyalBlue"
                        Foreground="White"
                        BorderThickness="0"
                        Click="SaveBtn_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>
