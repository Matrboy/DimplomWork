<Window x:Class="DimplomWork.Windows.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DimplomWork.Windows"
        mc:Ignorable="d"
              Title="Профиль пользователя" 
        Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
       >

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <!-- Левая колонка с данными -->
            <ColumnDefinition Width="200"/>
            <!-- Правая колонка с фото -->
        </Grid.ColumnDefinitions>

        <!-- Левая часть: Данные пользователя -->
        <StackPanel Grid.Column="1" Margin="0,0,5,0" VerticalAlignment="Center">
            <!-- Заголовок -->
            <TextBlock Text="ДАННЫЕ ПРОФИЛЯ" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="#34495E"
                       Margin="0,0,0,20"/>

            <!-- ФИО -->
            <TextBlock Text="ФИО:"/>
            <TextBox Text="{Binding full_name, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15"
                     Padding="8"
                     FontSize="13"/>

            <!-- Телефон -->
            <TextBlock Text="Телефон:" />
            <TextBox Text="{Binding phone, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15"
                     Padding="8"
                     FontSize="13"/>

            <!-- Email -->
            <TextBlock Text="Email:"/>
            <TextBox Text="{Binding email, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15"
                     Padding="8"
                     FontSize="13"/>

            <!-- Адрес -->
            <TextBlock Text="Адрес:"/>
            <TextBox Text="{Binding Orders.address, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15"
                     Padding="8"
                     FontSize="13"
                     TextWrapping="Wrap"
                     Height="60"/>

           
        </StackPanel>

        <!-- Правая часть: Фото профиля -->
        <Border Grid.Column="0" 
                BorderBrush="#BDC3C7" 
                BorderThickness="2" 
                CornerRadius="10"
                Background="#F8F9FA"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Width="180" Height="180">

            <Grid>
     
                <!-- Текст-заполнитель если фото недоступно -->
                <TextBlock Text="Фото профиля" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Foreground="#BDC3C7"
                           FontSize="14"
                           />
                
            </Grid>
            
        </Border>
        <StackPanel VerticalAlignment="Center" Margin="0,150,0,0">
            <Button Content="Редактировать данные" Background="Blue" Foreground="White" />
            <Button Content="Назад" Margin="0,30,0,0" Background="Blue" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>