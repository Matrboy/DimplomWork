<Window x:Class="DimplomWork.Windows.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DimplomWork.Windows"
        mc:Ignorable="d"
              Title="Профиль пользователя" 
        Height="400" Width="500"
         Icon="\Images\Мир Камня.png"
         ResizeMode="NoResize" WindowStartupLocation="CenterScreen">


    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <!-- Левая колонка с фото и кнопками -->
            <ColumnDefinition Width="*"/>
            <!-- Правая колонка с данными -->
        </Grid.ColumnDefinitions>

        <!-- ========== ЛЕВАЯ КОЛОНКА: Фото + Кнопки ========== -->
        <StackPanel Grid.Column="0" VerticalAlignment="Top">

            <!-- Фото профиля -->
            <Border BorderBrush="#BDC3C7" 
                    BorderThickness="2" 
                    CornerRadius="10"
                    Background="#F8F9FA"
                    Width="160" Height="160">

                <Grid>
                    <Image x:Name="ProfileImage" 
                           Stretch="UniformToFill"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                    <TextBlock x:Name="NoPhotoText" 
                               Text="📷 Фото профиля" 
                               TextAlignment="Center"
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               Foreground="#BDC3C7"
                               FontSize="14"/>
                </Grid>
            </Border>

            <!-- Кнопка Редактировать -->
            <Button x:Name="EditUserInfBtn" 
                    Content="✏️ Редактировать" 
                    Background="#3498DB" 
                    Foreground="White" 
                    Width="140" 
                    Height="35"
                    Margin="0,40,0,5"
                    Cursor="Hand"
                    Click="EditUserInfBtn_Click"/>

            <!-- Кнопки Сохранить и Отмена (появляются при редактировании) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,5">
                <Button x:Name="SaveBtn" 
                        Content="💾 Сохранить" 
                        Background="#27AE60" 
                        Foreground="White" 
                        Width="85" 
                        Height="35"
                        Margin="0,0,5,0"
                        Cursor="Hand"
                        Click="SaveBtn_Click"
                        Visibility="Collapsed"/>

                <Button x:Name="CancelBtn" 
                        Content="❌ Отмена" 
                        Background="#95A5A6" 
                        Foreground="White" 
                        Width="70" 
                        Height="35"
                        Cursor="Hand"
                        Click="CancelBtn_Click"
                        Visibility="Collapsed"/>
            </StackPanel>

            <!-- Кнопка Назад -->
            <Button x:Name="BackBtn" 
                    Content="← Назад" 
                    Background="#7F8C8D" 
                    Foreground="White" 
                    Width="100" 
                    Height="30"
                    Margin="0,15,0,0"
                    Cursor="Hand"
                    Click="BackBtn_Click"/>
        </StackPanel>

        <!-- ========== ПРАВАЯ КОЛОНКА: Данные пользователя ========== -->
        <StackPanel Grid.Column="1" Margin="15,0,0,0">
            <!-- Заголовок -->
            <TextBlock Text="ДАННЫЕ ПРОФИЛЯ" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="#34495E"
                       Margin="0,0,0,20"/>

            <!-- ФИО -->
            <TextBlock Text="ФИО:" FontWeight="SemiBold" Margin="0,5,0,2"/>
            <TextBox x:Name="FIOTb" 
                     Text="{Binding full_name, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15"
                     Padding="8"
                     FontSize="13"
                     IsEnabled="False"/>

            <!-- Телефон -->
            <TextBlock Text="Телефон:" FontWeight="SemiBold" Margin="0,5,0,2"/>
            <TextBox x:Name="PhoneTb" 
                     Text="{Binding phone, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15"
                     Padding="8"
                     FontSize="13"
                     IsEnabled="False"/>

            <!-- Email -->
            <TextBlock Text="Email:" FontWeight="SemiBold" Margin="0,5,0,2"/>
            <TextBox x:Name="EmailTb" 
                     Text="{Binding email, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15"
                     Padding="8"
                     FontSize="13"
                     IsEnabled="False"/>

            <!-- Статус (индикатор) -->
            <TextBlock x:Name="StatusTb" 
                       Text="" 
                       Foreground="Green"
                       FontSize="11"
                       Margin="0,5,0,5"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>