<Window x:Class="DimplomWork.Windows.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DimplomWork.Windows"
        mc:Ignorable="d"
        Title="RegistrationWindow" Height="450" Width="350">
    <Grid>
        <!-- Фоновый слой с изображением -->
        <Border CornerRadius="10" Margin="10" >
            <Grid>
              
                <!-- Кнопка закрытия -->
                <Button Content="X" Name="CloseBtn" HorizontalAlignment="Right" VerticalAlignment="Top"/>

                <!-- Центрированный контейнер с формой -->
                <Border Background="#EEE" CornerRadius="10" Padding="20" Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="240" >
                        <TextBlock Text="Регистрация" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <!-- Логин -->
                        <TextBlock Text="Введите полное ФИО:" />
                        <TextBox x:Name="FIOTb" Margin="0,5,0,10" />
                        
                        <!-- Логин -->
                        <TextBlock Text="Введите номер телефона :" />
                        <TextBox x:Name="PhoneTb" Margin="0,5,0,10" />

                        <!-- Пароль -->
                        <TextBlock Text="Введите адрес электронной почты:" />
                        <TextBox x:Name="EmailTb" Margin="0,5,0,20" />

                        <!-- Пароль -->
                        <TextBlock Text=" Придумайте логин:" />
                        <TextBox x:Name="LoginRegistrationTb" Margin="0,5,0,20" />
                        
                        <!-- Пароль -->
                        <TextBlock Text="Придумайте Пароль:" />
                        <PasswordBox x:Name="PasswordRegistrationPb" Margin="0,5,0,20" />

                        <!-- Кнопка Войти -->
                        <Button Content="Зарегестрироваться" Name="RegistrationBtn" Background="Blue" Foreground="White"
                               Click="RegistrationBtn_Click"  FontWeight="Bold"/>


                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
